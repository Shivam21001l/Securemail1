// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Nested collections in user profile
      match /profile/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /keys/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Mail folders
      match /inbox/{messageId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        // Allow anyone to send to this inbox
        allow create: if request.auth != null;
      }
      
      match /sent/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /trash/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /drafts/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Username directory (for lookup)
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Directories (UID -> username)
    match /directories/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
